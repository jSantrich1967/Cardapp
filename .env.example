# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database - NECESARIO para que funcione la app (Tarjetas, Resultados, etc.)
# Usa UNA de estas variables. Prioridad: SUPABASE_DIRECT_URL > SUPABASE_DATABASE_URL > DATABASE_URL

# CÓMO OBTENER LA URL (Dashboard Supabase actualizado 2024+):
# 1. Entra a https://supabase.com/dashboard y selecciona tu proyecto
# 2. Haz clic en el botón "Connect" (arriba a la derecha)
# 3. Elige "Direct connection" (5432) o "Transaction" (6543)
# 4. Copia la URI y reemplaza [YOUR-PASSWORD] por tu contraseña
# 5. Si la contraseña tiene *, usa %2A en su lugar

# Opción 1 - Directa (puerto 5432):
# SUPABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Opción 2 - Transaction pooler (puerto 6543, para serverless):
# SUPABASE_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres

# El PROJECT_REF está en la URL: .../project/[PROJECT_REF]
